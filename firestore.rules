rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Users can only read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Shared trip links are read-only for non-owners
    // 3. No collection allows public write access
    // 4. Unauthenticated users cannot read any trip data
    match /sharedTrips/{shareId} {
      allow read: if true; // Unauthenticated users can read shared trips via public link
      
      // Only the user who shared the trip can create/modify it
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sharedBy;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sharedBy;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
